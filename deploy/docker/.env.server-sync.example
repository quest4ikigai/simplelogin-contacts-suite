# SimpleLogin API key used to list aliases and reverse-alias contacts.
SIMPLELOGIN_API_KEY=replace_me

# Base URL for the SimpleLogin API.
SIMPLELOGIN_BASE_URL=https://app.simplelogin.io

# Timeout, in seconds, for SimpleLogin API requests.
SIMPLELOGIN_TIMEOUT_SECONDS=30

# Base URL for your Nextcloud instance.
NEXTCLOUD_BASE_URL=https://cloud.example.com

# Nextcloud username that owns the target address book.
NEXTCLOUD_USERNAME=username

# Nextcloud app password. Use an app password, not your primary account password.
NEXTCLOUD_APP_PASSWORD=replace_me

# Display name for the dedicated Nextcloud address book the sync creates or updates.
NEXTCLOUD_ADDRESSBOOK_DISPLAY_NAME=SimpleLogin

# CardDAV slug for the dedicated address book. Keep it lowercase and simple.
NEXTCLOUD_ADDRESSBOOK_SLUG=simplelogin

# Seconds to wait between sync runs inside the long-running container.
SYNC_INTERVAL_SECONDS=3600

# Log planned changes without writing to Nextcloud. Keep true for the first run.
DRY_RUN=true

# Delete generated contacts that no longer exist in SimpleLogin or no longer match filters.
DELETE_STALE=true

# Skip contacts attached to blocked/disabled SimpleLogin aliases.
SKIP_BLOCKED_CONTACTS=true

# Collapse duplicate reverse-alias contacts that resolve to the same original email.
DEDUPLICATE_CONTACTS_BY_ORIGINAL_EMAIL=true

# Optional regex. Only aliases matching this pattern are synced. Leave blank to sync all aliases.
# Example: @example\.net$
ALIAS_INCLUDE_REGEX=

# Optional regex. Aliases matching this pattern are skipped.
# Example: newsletter|throwaway
ALIAS_EXCLUDE_REGEX=

# Optional regex. Only reverse-alias contacts matching this pattern are synced.
# Example: @simplelogin\.co$
REVERSE_ALIAS_INCLUDE_REGEX=

# Optional regex. Reverse-alias contacts matching this pattern are skipped.
# Set blank to disable the default reply/no-reply filter.
REVERSE_ALIAS_EXCLUDE_REGEX=(?i)^(reply|no-reply)

# Optional path inside the container to a newline-separated reverse-alias exclude regex file.
REVERSE_ALIAS_EXCLUDE_REGEX_FILE=

# Prefix added to generated contact display names.
CONTACT_NAME_PREFIX=SL

# Logging verbosity: DEBUG, INFO, WARNING, ERROR, or CRITICAL.
LOG_LEVEL=INFO

# Redact email addresses in logs.
LOG_REDACT_ADDRESSES=true
