# Base URL for the SimpleLogin API.
SIMPLELOGIN_BASE_URL=https://app.simplelogin.io

# SimpleLogin API key used to list owned aliases and create reverse aliases.
SIMPLELOGIN_API_KEY=replace-me

# Timeout, in seconds, for SimpleLogin API requests.
SIMPLELOGIN_TIMEOUT_SECONDS=30

# Interface the SMTP proxy listens on inside the Docker container.
SMTP_PROXY_HOST=0.0.0.0

# Port the SMTP proxy listens on inside the Docker container.
SMTP_PROXY_PORT=2525

# Require SMTP AUTH before accepting outbound messages.
SMTP_PROXY_REQUIRE_AUTH=true

# Username Apple Mail or another SMTP client uses to authenticate to the proxy.
SMTP_PROXY_USERNAME=smtp-user

# Password Apple Mail or another SMTP client uses to authenticate to the proxy.
SMTP_PROXY_PASSWORD=replace-me

# Require inbound SMTP TLS at the proxy. Enable for remote clients.
SMTP_PROXY_REQUIRE_TLS=false

# Inbound TLS mode for Apple Mail/client connections: starttls or implicit.
# Use starttls for standard SMTP submission; use implicit if a client sends encrypted
# TLS bytes immediately after connecting.
SMTP_PROXY_TLS_MODE=starttls

# Certificate and private key paths inside the container for inbound client TLS.
# Mount the containing directory into the smtp-proxy service, such as ./certs:/certs:ro.
SMTP_PROXY_TLS_CERT_FILE=
SMTP_PROXY_TLS_KEY_FILE=

# Advertise AUTH LOGIN in addition to AUTH PLAIN for mail clients that prefer it.
SMTP_PROXY_AUTH_LOGIN_ENABLED=true

# Delay failed SMTP AUTH attempts to slow credential guessing.
SMTP_PROXY_AUTH_FAILURE_DELAY_SECONDS=1.0

# Maximum accepted message size in bytes.
SMTP_PROXY_MAX_MESSAGE_BYTES=26214400

# Reject after planning/logging instead of forwarding. Keep true for first tests.
SMTP_PROXY_DRY_RUN=true

# Hostname for the real upstream SMTP server, such as Proton Mail Bridge.
UPSTREAM_SMTP_HOST=host.docker.internal

# Port for the real upstream SMTP server.
UPSTREAM_SMTP_PORT=1025

# Username used when authenticating to the upstream SMTP server.
UPSTREAM_SMTP_USERNAME=replace-me

# Password used when authenticating to the upstream SMTP server.
UPSTREAM_SMTP_PASSWORD=replace-me

# Upstream SMTP TLS mode: none, starttls, or implicit.
# Use starttls for port 587-style submission and implicit for port 465-style SMTPS.
UPSTREAM_SMTP_TLS_MODE=none

# Verify the upstream SMTP server certificate and hostname.
# Keep true for normal use. Set false only for trusted self-signed upstreams.
UPSTREAM_SMTP_TLS_VERIFY=true

# Timeout, in seconds, for upstream SMTP connections and sends.
UPSTREAM_SMTP_TIMEOUT_SECONDS=30

# Real mailbox addresses you own. Messages must originate from one of these addresses.
USER_MAILBOXES=user@example.com,another@example.com

# Optional comma-separated aliases to trust locally if SimpleLogin discovery is unavailable.
MANUAL_SIMPLELOGIN_ALIASES=

# Optional comma-separated reverse aliases to seed into the cache for local testing.
KNOWN_REVERSE_ALIASES=

# Comma-separated suffix/domain patterns recognized as your SimpleLogin aliases in To, Cc, or Bcc.
# Examples: @example.net,@subdomain.simplelogin.example,.suffix@simplelogin.example
ALIAS_SUFFIX_DOMAINS=

# Reject messages when the proxy cannot prove the rewrite is safe.
FAIL_CLOSED=true

# Preserve unknown SimpleLogin-looking recipients instead of treating them as direct external sends.
KEEP_UNKNOWN_SIMPLELOGIN_ADDRESSES=true

# Remove your own SimpleLogin aliases from reply-all recipients.
STRIP_OWN_ALIASES=true

# Remove your own real mailbox addresses from reply-all recipients.
STRIP_OWN_MAILBOXES=true

# Allow direct delivery to external addresses. Keep false for normal privacy-preserving use.
ALLOW_DIRECT_EXTERNAL_SEND=false

# SQLite cache path for discovered aliases and reverse aliases.
CACHE_PATH=/data/cache.sqlite3

# Time, in seconds, before cached owned aliases are refreshed.
CACHE_ALIAS_TTL_SECONDS=3600

# Time, in seconds, before cached reverse-alias contact lookups are refreshed.
CACHE_CONTACT_TTL_SECONDS=86400

# Logging verbosity: DEBUG, INFO, WARNING, ERROR, or CRITICAL.
LOG_LEVEL=INFO

# Redact email addresses in logs.
LOG_REDACT_ADDRESSES=true

# Allow message bodies in logs. Keep false unless debugging locally with test data.
LOG_MESSAGE_BODY=false

# Allow email subjects in logs. Keep false unless debugging locally with test data.
LOG_SUBJECT=false
